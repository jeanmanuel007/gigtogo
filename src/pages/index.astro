---
import Layout from "../layouts/layout.astro";

const featuredShifts = [
  {
    role: "Barista",
    company: "Insomnia Coffee",
    time: "Today · 2:00 PM - 8:00 PM",
    pay: "€14.50/hr",
    location: "Stoneybatter",
    logo: "/insomnia.jpg",
  },
  {
    role: "Kitchen Porter",
    company: "Forno 500",
    time: "Sat · 12:00 PM - 6:00 PM",
    pay: "€15.80/hr",
    location: "Dame Street",
    logo: "/forno.jpg",
  },
  {
    role: "Front of House",
    company: "Maldron Hotel",
    time: "Mon · 9:00 AM - 5:00 PM",
    pay: "€15.40/hr",
    location: "Smithfield",
    logo: "/maldron.jpg",
  },
];
---

<Layout title="GigToGo">
  <main>
    <section class="home-hero">
      <header class="home-nav">
        <div class="container">
          <a href="/" class="home-logo" aria-label="GigToGo home">
            <img src="/GigToGo_logo_white.svg" alt="GigToGo" />
          </a>

          <nav class="home-nav-links" aria-label="Home navigation">
            <a href="#how-it-works">How it works</a>
            <a href="#live-shifts">Live shifts</a>
            <a href="#for-business">For businesses</a>
          </nav>

          <div class="nav-actions">
            <a href="/auth/signin" class="btn btn-secondary">Sign in</a>
            <a href="/auth/register" class="btn btn-primary">Get started</a>
          </div>
        </div>
      </header>

      <div class="home-hero-stage">
        <div class="container home-hero-grid">
          <div class="home-hero-copy">
            <p class="home-eyebrow">Flexible work across Dublin</p>
            <h1>Find shifts today. Get paid faster.</h1>
            <p>
              GigToGo helps workers find nearby hospitality shifts and helps businesses fill urgent roles with verified people.
            </p>

            <div class="home-hero-actions">
              <a href="/auth/register" class="btn btn-primary">
                Find shifts
                <i class="fa-solid fa-arrow-right"></i>
              </a>
              <a href="/business/create-shift" class="btn btn-secondary">Post a shift</a>
            </div>

          </div>
        </div>
      </div>
    </section>

    <section class="section home-role-section">
      <div class="container">
        <div class="home-role-grid">
          <article class="home-role-card">
            <i class="fa-solid fa-user-clock"></i>
            <h2>I want flexible work</h2>
            <p>Browse shifts, apply quickly, clock in, and track payment from your worker dashboard.</p>
            <a href="/auth/register" class="btn btn-primary">Join as worker</a>
          </article>

          <article class="home-role-card business" id="for-business">
            <i class="fa-solid fa-shop"></i>
            <h2>I need staff</h2>
            <p>Post shifts, review applicants, and fill last-minute hospitality gaps with less admin.</p>
            <a href="/business/create-shift" class="btn btn-secondary">Hire staff</a>
          </article>
        </div>
      </div>
    </section>

    <section class="section home-how" id="how-it-works">
      <div class="container">
        <p class="section-kicker">How GigToGo works</p>
        <h2 class="section-title">Three steps from profile to payday</h2>

        <div class="home-step-grid">
          <article>
            <span>1</span>
            <h3>Create your profile</h3>
            <p>Add your skills, availability, and location so the right shifts surface first.</p>
          </article>

          <article>
            <span>2</span>
            <h3>Apply or post</h3>
            <p>Workers apply in minutes. Businesses review applicants from one simple dashboard.</p>
          </article>

          <article>
            <span>3</span>
            <h3>Work and track pay</h3>
            <p>Clock in for shifts, view upcoming work, and see what payment is on the way.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section home-live" id="live-shifts">
      <div class="container">
        <div class="home-section-head">
          <div>
            <p class="section-kicker">Live opportunities</p>
            <h2>Popular shifts near you</h2>
          </div>
          <a href="/worker/shifts">View all shifts</a>
        </div>

        <div class="home-shift-grid">
          {featuredShifts.map((shift) => (
            <article class="home-shift-card">
              <img src={shift.logo} alt="" />
              <div>
                <strong>{shift.role}</strong>
                <span>{shift.company}</span>
                <small>{shift.location} · {shift.time}</small>
              </div>
              <em>{shift.pay}</em>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section home-proof">
      <div class="container home-proof-grid">
        <div>
          <p class="section-kicker">Built for real shifts</p>
          <h2>Everything after login is ready for the workday.</h2>
          <p>
            Workers get a home dashboard with available shifts, next shifts, applications, messages, notifications, clock-in tools, and payment tracking.
          </p>
        </div>

        <div class="home-dashboard-snapshot" aria-label="Worker dashboard features">
          <div>
            <i class="fa-regular fa-calendar-check"></i>
            <span>Next shift</span>
            <strong>Today · 14:00</strong>
          </div>
          <div>
            <i class="fa-solid fa-stopwatch"></i>
            <span>Clock in</span>
            <strong>Ready</strong>
          </div>
          <div>
            <i class="fa-solid fa-wallet"></i>
            <span>To receive</span>
            <strong>€428</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="section testimonials">
      <div class="container">
        <p class="section-kicker">Trusted locally</p>
        <h2 class="section-title">Workers and businesses stay in sync</h2>

        <div class="cards">
          <article class="card">
            <div class="avatar">A</div>
            <strong>Aoife · Worker</strong>
            <main>
              I can see shifts, apply, and keep track of what I have earned in one place.
            </main>
          </article>

          <article class="card main-card">
            <div class="avatar">M</div>
            <strong>Mary · Worker</strong>
            <main>
              The clock-in and payment view makes each shift much easier to manage.
            </main>
            <div class="stars">★★★★★</div>
          </article>

          <article class="card">
            <div class="avatar">G</div>
            <strong>Grano · Business</strong>
            <main>
              We can post urgent shifts and review applicants without chasing messages.
            </main>
          </article>
        </div>
      </div>
    </section>

    <section class="section cta">
      <div class="container">
        <div class="home-cta-box">
          <div>
            <img src="/GigToGo_logo.svg" alt="GigToGo" />
            <h2>Ready to start with GigToGo?</h2>
            <p>Choose worker or business and get to the right dashboard in a few clicks.</p>
          </div>

          <div class="home-cta-actions">
            <a href="/auth/register" class="btn btn-primary">Create account</a>
            <a href="/auth/signin" class="btn btn-secondary">Sign in</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
