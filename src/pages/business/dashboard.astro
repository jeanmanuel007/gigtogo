---
import Layout from "../../layouts/layout.astro";
import AppSidebar from "../../components/AppSidebar.astro";
import WorkerTopActions from "../../components/workerTopActions.astro";
import { getCoverImage, getProfileImage } from "../../lib/profileImages";
import { hasSupabaseConfig, supabaseFetch } from "../../lib/supabaseServer";

export const prerender = false;

const token = Astro.cookies.get("gigtogo_access_token")?.value;
const userId = Astro.cookies.get("gigtogo_user_id")?.value;

let businessName = "Business";
let businessImage = getProfileImage();
let coverImage = getCoverImage();
let activeShifts: Array<any> = [];
let applicants: Array<any> = [];
let acceptedCount = 0;
let pendingCount = 0;

if (hasSupabaseConfig() && !token) {
  return Astro.redirect("/auth/signin?error=Please sign in to view your dashboard.");
}

if (hasSupabaseConfig() && token && userId) {
  try {
    const rows = await supabaseFetch(
      `/rest/v1/profiles?id=eq.${userId}&select=full_name,profile_image_path&limit=1`,
      { token }
    );
    businessName = rows?.[0]?.full_name ?? businessName;
    businessImage = getProfileImage(rows?.[0]?.profile_image_path);
  } catch {
    businessName = "Business";
    businessImage = getProfileImage();
  }

  try {
    const shiftRows = await supabaseFetch(
      `/rest/v1/shifts?business_id=eq.${userId}&select=id,title,location,shift_date,start_time,end_time,status&order=created_at.desc&limit=5`,
      { token }
    );
    const shiftIds = shiftRows.map((shift: any) => shift.id);
    const applicationRows = shiftIds.length
      ? await supabaseFetch(
          `/rest/v1/shift_applications?shift_id=in.(${shiftIds.join(",")})&select=id,status,shift_id,worker_id&order=created_at.desc`,
          { token }
        )
      : [];
    const workerIds = Array.from(
      new Set(applicationRows.map((application: any) => application.worker_id).filter(Boolean))
    );
    const workerProfiles = new Map();

    if (workerIds.length > 0) {
      const workerRows = await supabaseFetch(
        `/rest/v1/profiles?id=in.(${workerIds.join(",")})&select=id,full_name,profile_image_path`,
        { token }
      );

      for (const worker of workerRows) {
        workerProfiles.set(worker.id, worker);
      }
    }

    const applicantCount = new Map();

    for (const application of applicationRows) {
      const count = applicantCount.get(application.shift_id) ?? 0;
      applicantCount.set(application.shift_id, count + 1);

      if (application.status === "accepted") acceptedCount += 1;
      if (application.status === "pending") pendingCount += 1;
    }

    activeShifts = shiftRows.map((shift: any) => ({
      id: shift.id,
      title: shift.title,
      location: shift.location,
      time: `${shift.shift_date} · ${shift.start_time.slice(0, 5)} - ${shift.end_time.slice(0, 5)}`,
      applicants: applicantCount.get(shift.id) ?? 0,
      status: shift.status,
    }));

    applicants = applicationRows
      .filter((application: any) => application.status === "pending")
      .slice(0, 3)
      .map((application: any) => {
        const worker = workerProfiles.get(application.worker_id);
        const name = worker?.full_name ?? "Worker";

        return {
          name,
          role: activeShifts.find((shift) => shift.id === application.shift_id)?.title ?? "Shift applicant",
          avatar: name.slice(0, 1).toUpperCase(),
          image: worker?.profile_image_path ?? "",
        };
      });
  } catch {
    activeShifts = [];
    applicants = [];
  }
}
---

<Layout title="Business Dashboard | GigToGo">
  <main class="worker-ui">
    <AppSidebar accountType="business" active="dashboard" />

    <section class="worker-ui-main business-dashboard-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search shifts, applicants or messages" />
        </div>

        <WorkerTopActions active="dashboard" accountType="business" avatarImage={businessImage} />
      </header>

      <div class="worker-ui-breadcrumb">
        <span>Business</span>
        <span>/</span>
        <strong>Dashboard</strong>
      </div>

      <section class="business-dashboard-hero" style={`--business-cover: url("${coverImage}")`}>
        <div>
          <p>Business dashboard</p>
          <h1>Hi, {businessName}</h1>
          <span>Post urgent shifts, review candidates, and keep every role moving from one place.</span>
          <div class="business-dashboard-hero-actions">
            <a href="/business/create-shift" class="btn btn-primary">
              Post a shift
              <i class="fa-solid fa-arrow-right"></i>
            </a>
            <a href="/business/applications" class="btn btn-secondary">Review applicants</a>
          </div>
        </div>
      </section>

      <section class="worker-dashboard-stats" aria-label="Business dashboard summary">
        <article>
          <i class="fa-regular fa-calendar"></i>
          <strong>{activeShifts.length}</strong>
          <span>Active shifts</span>
        </article>
        <article>
          <i class="fa-regular fa-file-lines"></i>
          <strong>{pendingCount}</strong>
          <span>Applicants</span>
        </article>
        <article>
          <i class="fa-solid fa-user-check"></i>
          <strong>{acceptedCount}</strong>
          <span>Accepted</span>
        </article>
        <article>
          <i class="fa-solid fa-bolt"></i>
          <strong>{activeShifts.filter((shift) => shift.status === "open").length}</strong>
          <span>Open roles</span>
        </article>
      </section>

      <section class="business-dashboard-grid">
        <article class="worker-profile-panel business-dashboard-shifts">
          <div class="worker-profile-panel-head">
            <div>
              <p>Hiring pipeline</p>
              <h2>Active shifts</h2>
            </div>
            <a href="/business/shifts">See all</a>
          </div>

          <div class="business-dashboard-shift-list">
            {activeShifts.map((shift) => (
              <a href="/business/shifts">
                <span>{shift.status}</span>
                <div>
                  <strong>{shift.title}</strong>
                  <small>{shift.location} · {shift.time}</small>
                </div>
                <em>{shift.applicants} applicants</em>
              </a>
            ))}
            {activeShifts.length === 0 && (
              <p class="worker-profile-bio">Your posted shifts will appear here.</p>
            )}
          </div>
        </article>

        <article class="worker-profile-panel business-dashboard-applicants">
          <div class="worker-profile-panel-head">
            <div>
              <p>Applicants</p>
              <h2>Needs review</h2>
            </div>
            <a href="/business/applications">Open</a>
          </div>

          <div class="business-dashboard-applicant-list">
            {applicants.map((applicant) => (
              <a href="/business/applications">
                <span>
                  {applicant.image ? <img src={applicant.image} alt={applicant.name} /> : applicant.avatar}
                </span>
                <div>
                  <strong>{applicant.name}</strong>
                  <small>{applicant.role} · pending review</small>
                </div>
              </a>
            ))}
            {applicants.length === 0 && (
              <p class="worker-profile-bio">New applications will appear here.</p>
            )}
          </div>
        </article>

        <article class="worker-profile-panel business-dashboard-actions">
          <div class="worker-profile-panel-head">
            <div>
              <p>Quick actions</p>
              <h2>Run staffing faster</h2>
            </div>
          </div>

          <div class="business-dashboard-action-grid">
            <a href="/business/create-shift">
              <i class="fa-solid fa-circle-plus"></i>
              <strong>Create shift</strong>
              <span>Publish a new opening</span>
            </a>
            <a href="/business/applications">
              <i class="fa-solid fa-user-check"></i>
              <strong>Accept worker</strong>
              <span>Review applications</span>
            </a>
            <a href="/business/shifts">
              <i class="fa-regular fa-calendar-check"></i>
              <strong>Manage shifts</strong>
              <span>Track open roles</span>
            </a>
          </div>
        </article>

        <article class="worker-profile-panel business-dashboard-note">
          <div class="worker-profile-panel-head">
            <div>
              <p>Today</p>
              <h2>Staffing note</h2>
            </div>
            <span>Live</span>
          </div>

          <p>
            Review new applications and keep your open shifts up to date.
          </p>
        </article>
      </section>
    </section>
  </main>
</Layout>
