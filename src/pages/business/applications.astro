---
import Layout from "../../layouts/layout.astro";
import AppSidebar from "../../components/AppSidebar.astro";
import { hasSupabaseConfig, supabaseFetch } from "../../lib/supabaseServer";

export const prerender = false;

const fallbackApplicants = [
  {
    applicationId: "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
    shiftId: "11111111-1111-4111-8111-111111111111",
    workerId: "77777777-7777-4777-8777-777777777777",
    name: "Rose Murphy",
    role: "Barista",
    shift: "Barista | 20 hours/week",
    location: "Stoneybatter",
    experience: "2 years experience",
    rating: "4.9",
    status: "pending",
    avatar: "R",
  },
  {
    applicationId: "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb",
    shiftId: "44444444-4444-4444-8444-444444444444",
    workerId: "88888888-8888-4888-8888-888888888888",
    name: "Daniel O'Brien",
    role: "Wait Staff",
    shift: "Wait Staff | Weekend shift",
    location: "Dublin City Centre",
    experience: "1 year experience",
    rating: "4.7",
    status: "pending",
    avatar: "D",
  },
  {
    applicationId: "cccccccc-cccc-4ccc-8ccc-cccccccccccc",
    shiftId: "33333333-3333-4333-8333-333333333333",
    workerId: "99999999-9999-4999-8999-999999999999",
    name: "Aoife Kelly",
    role: "Kitchen Porter",
    shift: "Kitchen Porter | Evening shift",
    location: "Smithfield",
    experience: "3 years experience",
    rating: "5.0",
    status: "pending",
    avatar: "A",
  },
];

const token = Astro.cookies.get("gigtogo_access_token")?.value;
const userId = Astro.cookies.get("gigtogo_user_id")?.value;
const error = Astro.url.searchParams.get("error");
const notice = Astro.url.searchParams.get("notice");

let applicants = fallbackApplicants;

if (hasSupabaseConfig() && token && userId) {
  try {
    const rows = await supabaseFetch(
      `/rest/v1/shift_applications?select=id,status,note,worker_id,shift_id,profiles!shift_applications_worker_id_fkey(full_name,email,headline,bio,skills,experience,availability,location),shifts!inner(title,location,business_id)&shifts.business_id=eq.${userId}&order=created_at.desc`,
      { token }
    );

    const realApplicants = rows.map((row: any) => {
      const profile = row.profiles ?? {};
      const skills = Array.isArray(profile.skills) ? profile.skills.filter(Boolean) : [];
      const profileSummary =
        profile.experience ||
        profile.bio ||
        profile.availability ||
        row.note ||
        "Application received and ready for review.";

      return {
        applicationId: row.id,
        shiftId: row.shift_id,
        workerId: row.worker_id,
        name: profile.full_name ?? profile.email ?? "Worker",
        role: profile.headline ?? "Applicant",
        shift: row.shifts?.title ?? "Shift",
        location: profile.location ?? row.shifts?.location ?? "Location pending",
        experience: profileSummary,
        skills: skills.slice(0, 3).join(" · "),
        rating: row.status === "accepted" ? "Booked" : "New",
        status: row.status,
        avatar: (profile.full_name ?? profile.email ?? "W").slice(0, 1).toUpperCase(),
      };
    });

    applicants = [...realApplicants, ...fallbackApplicants];
  } catch {
    applicants = fallbackApplicants;
  }
}

const statusLabels: Record<string, string> = {
  pending: "Pending review",
  accepted: "Accepted",
  rejected: "Rejected",
  cancelled: "Cancelled by worker",
};
---

<Layout title="Applicants | GigToGo">
  <main class="worker-ui">

    <!-- SIDEBAR -->
    <AppSidebar accountType="business" active="applications" />

    <!-- MAIN -->
    <section class="worker-ui-main">

      <h2 style="margin-bottom: 20px; color: var(--blue);">
        Applicants for your shifts
      </h2>

      {error && <p class="auth-alert error">{error}</p>}
      {notice && <p class="auth-alert notice">{notice}</p>}

      <div class="business-applicant-grid">

        {applicants.map((user) => (
          <article class="business-applicant-card">
            <div class="business-applicant-top">
              <div class="business-applicant-avatar">
                {user.avatar}
              </div>

              <div>
                <h3>{user.name}</h3>
                <p>{user.role}</p>
              </div>

              <span>{statusLabels[user.status] ?? user.status}</span>
            </div>

            <div class="business-applicant-info">
              <p>
                <i class="fa-solid fa-briefcase"></i>
                {user.shift}
              </p>
              <p>
                <i class="fa-solid fa-location-dot"></i>
                {user.location}
              </p>
              <p>
                <i class="fa-solid fa-graduation-cap"></i>
                {user.experience}
              </p>
              {user.skills && (
                <p>
                  <i class="fa-solid fa-star"></i>
                  {user.skills}
                </p>
              )}
              <p>
                <i class="fa-solid fa-circle-check"></i>
                {user.rating}
              </p>
            </div>

            <div class="business-applicant-actions">
              {user.status === "pending" ? (
                <>
                <form method="POST" action="/api/applications/accept">
                  <input type="hidden" name="application_id" value={user.applicationId} />
                  <input type="hidden" name="shift_id" value={user.shiftId} />
                  <input type="hidden" name="worker_id" value={user.workerId} />
                  <button class="business-btn-primary" type="submit">Accept</button>
                </form>
                <form method="POST" action="/api/applications/reject">
                  <input type="hidden" name="application_id" value={user.applicationId} />
                  <button class="business-btn-outline" type="submit">Reject</button>
                </form>
                </>
              ) : user.status === "accepted" ? (
                <>
                  <span class="business-applicant-accepted">
                    <i class="fa-solid fa-circle-check"></i>
                    Accepted
                  </span>
                  <form method="POST" action="/api/applications/reject">
                    <input type="hidden" name="application_id" value={user.applicationId} />
                    <input type="hidden" name="shift_id" value={user.shiftId} />
                    <input type="hidden" name="worker_id" value={user.workerId} />
                    <input type="hidden" name="intent" value="cancel" />
                    <button class="business-btn-outline" type="submit">Cancel application</button>
                  </form>
                </>
              ) : (
                <span class="business-applicant-closed">{statusLabels[user.status] ?? user.status}</span>
              )}
            </div>
          </article>
        ))}

      </div>

    </section>

  </main>
</Layout>
