---
import Layout from "../../layouts/layout.astro";
import AppSidebar from "../../components/AppSidebar.astro";
import WorkerTopActions from "../../components/workerTopActions.astro";

const supportOptions = [
  {
    title: "Shift posting",
    detail: "Help creating, editing or reopening posted shifts.",
    icon: "fa-regular fa-calendar-check",
  },
  {
    title: "Applicants",
    detail: "Questions about reviewing, accepting or cancelling applications.",
    icon: "fa-solid fa-user-check",
  },
  {
    title: "Business profile",
    detail: "Support with venue details, account settings and billing readiness.",
    icon: "fa-regular fa-building",
  },
];

const contactMethods = [
  {
    label: "Email",
    value: "business@gigtogo.com",
    icon: "fa-regular fa-envelope",
  },
  {
    label: "Phone",
    value: "+353 89 123 4567",
    icon: "fa-solid fa-phone",
  },
  {
    label: "Hours",
    value: "Mon-Fri · 9:00-17:00",
    icon: "fa-regular fa-clock",
  },
];
---

<Layout title="Business Contact Us | GigToGo">
  <main class="worker-ui">
    <AppSidebar accountType="business" active="contact" />

    <section class="worker-ui-main worker-contact-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search hiring support or account help" />
        </div>

        <WorkerTopActions active="contact" accountType="business" />
      </header>

      <div class="worker-ui-breadcrumb">
        <span>Business</span>
        <span>/</span>
        <strong>Contact Us</strong>
      </div>

      <section class="worker-contact-hero">
        <div>
          <p>Business support</p>
          <h1>Get help with shifts, applicants and your venue profile.</h1>
          <span>Send a message to the GigToGo team and we will help keep your hiring moving.</span>
        </div>
      </section>

      <section class="worker-contact-grid">
        <article class="worker-profile-panel worker-contact-form-panel">
          <div class="worker-profile-panel-head">
            <div>
              <p>Message</p>
              <h2>Contact support</h2>
            </div>
            <span>Demo form</span>
          </div>

          <form class="worker-contact-form">
            <div class="business-form-grid">
              <label>
                <span>Business name</span>
                <input type="text" placeholder="Your business name" />
              </label>

              <label>
                <span>Email</span>
                <input type="email" placeholder="business@example.com" />
              </label>

              <label class="business-form-full">
                <span>Topic</span>
                <select>
                  <option>Shift posting</option>
                  <option>Applicants</option>
                  <option>Business profile</option>
                  <option>Other</option>
                </select>
              </label>
            </div>

            <label class="business-form-full">
              <span>Message</span>
              <textarea rows="6" placeholder="Tell us what you need help with and include any shift or applicant details."></textarea>
            </label>

            <div class="business-form-actions">
              <button type="button" class="btn btn-primary">
                Send message
                <i class="fa-solid fa-arrow-right"></i>
              </button>
            </div>
          </form>
        </article>

        <aside class="worker-profile-panel worker-contact-methods">
          <div class="worker-profile-panel-head">
            <div>
              <p>Reach us</p>
              <h2>Contact details</h2>
            </div>
          </div>

          <div class="worker-contact-method-list">
            {contactMethods.map((method) => (
              <article>
                <i class={method.icon}></i>
                <div>
                  <strong>{method.label}</strong>
                  <span>{method.value}</span>
                </div>
              </article>
            ))}
          </div>
        </aside>

        <section class="worker-contact-options">
          {supportOptions.map((option) => (
            <article class="worker-profile-panel">
              <i class={option.icon}></i>
              <strong>{option.title}</strong>
              <p>{option.detail}</p>
            </article>
          ))}
        </section>
      </section>
    </section>
  </main>
</Layout>
