---
import Layout from "../../layouts/layout.astro";
import AppSidebar from "../../components/AppSidebar.astro";
import WorkerTopActions from "../../components/workerTopActions.astro";
import { hasSupabaseConfig, supabaseFetch } from "../../lib/supabaseServer";

export const prerender = false;

const token = Astro.cookies.get("gigtogo_access_token")?.value;
const userId = Astro.cookies.get("gigtogo_user_id")?.value;
const emailCookie = Astro.cookies.get("gigtogo_user_email")?.value ?? "";
const error = Astro.url.searchParams.get("error");
const notice = Astro.url.searchParams.get("notice");

let profile = {
  fullName: "Worker Profile",
  email: emailCookie,
  phone: "",
  location: "Dublin, Ireland",
  headline: "Hospitality worker",
  bio: "",
  skills: [] as string[],
  experience: "",
  availability: "",
};

let applicationCount = 0;
let acceptedCount = 0;

if (hasSupabaseConfig() && !token) {
  return Astro.redirect("/auth/signin?error=Please sign in to view your profile.");
}

if (hasSupabaseConfig() && token && userId) {
  try {
    const rows = await supabaseFetch(
      `/rest/v1/profiles?id=eq.${userId}&select=full_name,email,phone,location,headline,bio,skills,experience,availability&limit=1`,
      { token }
    );
    const row = rows?.[0];

    if (row) {
      profile = {
        fullName: row.full_name ?? profile.fullName,
        email: row.email ?? emailCookie,
        phone: row.phone ?? "",
        location: row.location ?? "Dublin, Ireland",
        headline: row.headline ?? "Hospitality worker",
        bio: row.bio ?? "",
        skills: Array.isArray(row.skills) ? row.skills : [],
        experience: row.experience ?? "",
        availability: row.availability ?? "",
      };
    }

    const applications = await supabaseFetch(
      `/rest/v1/shift_applications?worker_id=eq.${userId}&select=id,status`,
      { token }
    );
    applicationCount = applications.length;
    acceptedCount = applications.filter((application: any) => application.status === "accepted").length;
  } catch {
    try {
      const rows = await supabaseFetch(
        `/rest/v1/profiles?id=eq.${userId}&select=full_name,email&limit=1`,
        { token }
      );
      const row = rows?.[0];

      if (row) {
        profile = {
          ...profile,
          fullName: row.full_name ?? profile.fullName,
          email: row.email ?? emailCookie,
        };
      }
    } catch {
      // Keep the profile page usable while Supabase fields are being migrated.
    }
  }
}

const skillsText = profile.skills.join(", ");
const completionItems = [
  profile.fullName,
  profile.phone,
  profile.location,
  profile.headline,
  profile.bio,
  profile.skills.length > 0 ? "skills" : "",
  profile.experience,
  profile.availability,
];
const completion = Math.round((completionItems.filter(Boolean).length / completionItems.length) * 100);
---

<Layout title="Worker Profile | GigToGo">
  <main class="worker-ui">
    <AppSidebar accountType="worker" active="profile" />

    <section class="worker-ui-main worker-profile-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search profile details or applications" />
        </div>

        <WorkerTopActions active="profile" displayName={profile.fullName} />
      </header>

      <div class="worker-ui-breadcrumb">
        <span>Worker</span>
        <span>/</span>
        <strong>Profile</strong>
      </div>

      {error && <p class="auth-alert error">{error}</p>}
      {notice && <p class="auth-alert notice">{notice}</p>}

      <section class="worker-profile-hero">
        <img src="/image_home_1.png" alt="Profile cover" />
        <div class="worker-profile-hero-overlay"></div>

        <div class="worker-profile-identity">
          <span class="worker-profile-avatar-large">
            <img src="/mary.jpg" alt={profile.fullName} />
          </span>
          <div>
            <p>{profile.headline || "Worker profile"}</p>
            <h1>{profile.fullName}</h1>
            <span>{profile.location} · {profile.email}</span>
          </div>
          <a href="#edit-profile" class="btn btn-primary">
            Edit profile
            <i class="fa-regular fa-pen-to-square"></i>
          </a>
        </div>
      </section>

      <section class="worker-profile-stats" aria-label="Worker profile summary">
        <article>
          <i class="fa-regular fa-user"></i>
          <div>
            <span>Profile</span>
            <strong>{completion}%</strong>
            <small>complete</small>
          </div>
        </article>
        <article>
          <i class="fa-regular fa-file-lines"></i>
          <div>
            <span>Applications</span>
            <strong>{applicationCount}</strong>
            <small>{acceptedCount} accepted</small>
          </div>
        </article>
        <article>
          <i class="fa-solid fa-graduation-cap"></i>
          <div>
            <span>Skills</span>
            <strong>{profile.skills.length}</strong>
            <small>listed on profile</small>
          </div>
        </article>
        <article>
          <i class="fa-regular fa-calendar-check"></i>
          <div>
            <span>Availability</span>
            <strong>{profile.availability ? "Set" : "Add"}</strong>
            <small>{profile.availability ? "ready for shifts" : "your schedule"}</small>
          </div>
        </article>
      </section>

      <section class="worker-profile-grid">
        <article class="worker-profile-panel worker-profile-about">
          <div class="worker-profile-panel-head">
            <div>
              <p>Overview</p>
              <h2>Public profile</h2>
            </div>
            <span>{completion}% complete</span>
          </div>

          <p class="worker-profile-bio">
            {profile.bio || "Add a short profile summary so businesses know what kind of work you are looking for."}
          </p>

          <div class="worker-profile-info-list">
            <p>
              <i class="fa-solid fa-location-dot"></i>
              {profile.location || "Location not added"}
            </p>
            <p>
              <i class="fa-regular fa-envelope"></i>
              {profile.email}
            </p>
            <p>
              <i class="fa-solid fa-phone"></i>
              {profile.phone || "Phone not added"}
            </p>
            <p>
              <i class="fa-solid fa-briefcase"></i>
              {profile.experience || "Experience not added"}
            </p>
          </div>

          <div class="worker-profile-skill-list" aria-label="Worker skills">
            {profile.skills.length === 0 ? <span>Add skills below</span> : profile.skills.map((skill) => <span>{skill}</span>)}
          </div>
        </article>

        <article class="worker-profile-panel worker-profile-availability">
          <div class="worker-profile-panel-head">
            <div>
              <p>Preferences</p>
              <h2>Availability</h2>
            </div>
          </div>

          <p class="worker-profile-bio">
            {profile.availability || "Add when you are usually available for shifts."}
          </p>
        </article>

        <article class="worker-profile-panel worker-profile-edit-panel" id="edit-profile">
          <div class="worker-profile-panel-head">
            <div>
              <p>Edit</p>
              <h2>Profile details</h2>
            </div>
            <span>Saved to Supabase</span>
          </div>

          <form method="POST" action="/api/profile/update" class="worker-profile-edit-form">
            <input type="hidden" name="back_to" value="/worker/profile" />
            <div class="business-form-grid">
              <label>
                <span>Full name</span>
                <input name="full_name" type="text" value={profile.fullName} required />
              </label>

              <label>
                <span>Email</span>
                <input type="email" value={profile.email} readonly />
              </label>

              <label>
                <span>Phone</span>
                <input name="phone" type="tel" value={profile.phone} placeholder="+353 89 123 4567" />
              </label>

              <label>
                <span>Location</span>
                <input name="location" type="text" value={profile.location} placeholder="Dublin, Ireland" />
              </label>

              <label class="business-form-full">
                <span>Headline</span>
                <input name="headline" type="text" value={profile.headline} placeholder="Hospitality worker, barista, event staff" />
              </label>
            </div>

            <label class="business-form-full">
              <span>Bio</span>
              <textarea name="bio" rows="4" placeholder="Write a short summary for businesses.">{profile.bio}</textarea>
            </label>

            <label class="business-form-full">
              <span>Skills</span>
              <input name="skills" type="text" value={skillsText} placeholder="Barista, POS, customer service, food safety" />
            </label>

            <label class="business-form-full">
              <span>Experience</span>
              <textarea name="experience" rows="4" placeholder="Describe your previous roles, industries, certificates, and strengths.">{profile.experience}</textarea>
            </label>

            <label class="business-form-full">
              <span>Availability</span>
              <textarea name="availability" rows="3" placeholder="Example: Weekdays after 4pm, weekends, short notice shifts.">{profile.availability}</textarea>
            </label>

            <div class="business-form-actions">
              <a href="/worker/dashboard" class="btn btn-secondary">Back to dashboard</a>
              <button type="submit" class="btn btn-primary">
                Save profile
                <i class="fa-solid fa-check"></i>
              </button>
            </div>
          </form>
        </article>
      </section>
    </section>
  </main>
</Layout>
