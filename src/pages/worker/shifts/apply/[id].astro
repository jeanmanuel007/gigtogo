---
import Layout from "../../../../layouts/layout.astro";
import AppSidebar from "../../../../components/AppSidebar.astro";
import WorkerTopActions from "../../../../components/workerTopActions.astro";
import { getProfileImage } from "../../../../lib/profileImages";
import { hasSupabaseConfig, supabaseFetch } from "../../../../lib/supabaseServer";

export const prerender = false;

const token = Astro.cookies.get("gigtogo_access_token")?.value;
const userId = Astro.cookies.get("gigtogo_user_id")?.value;
const id = Astro.params.id ?? "";
let workerImage = getProfileImage();

let shift = {
  id,
  title: "Shift",
  company: "Business",
  location: "Dublin",
  address: "Dublin",
  time: "Time to be confirmed",
  pay: "Pay to be confirmed",
  total: "Estimated total shown after hours are confirmed",
  logo: getProfileImage(),
  image: "/image_home_1.png",
};

if (hasSupabaseConfig() && !token) {
  return Astro.redirect("/auth/signin?error=Please sign in to apply for shifts.");
}

if (hasSupabaseConfig() && token && id) {
  try {
    if (userId) {
      const workerRows = await supabaseFetch(
        `/rest/v1/profiles?id=eq.${userId}&select=profile_image_path&limit=1`,
        { token }
      );
      workerImage = getProfileImage(workerRows?.[0]?.profile_image_path);
    }

    const rows = await supabaseFetch(
      `/rest/v1/shifts?id=eq.${id}&select=id,title,company,business_id,location,shift_date,start_time,end_time,pay_rate&limit=1`,
      { token }
    );
    const row = rows?.[0];

    if (!row) {
      return Astro.redirect("/worker/shifts?error=Shift not found.");
    }

    let companyName = row.company;
    let companyLogo = getProfileImage();

    try {
      const profileRows = await supabaseFetch(
        `/rest/v1/profiles?id=eq.${row.business_id}&select=full_name,profile_image_path&limit=1`,
        { token }
      );
      companyName = profileRows?.[0]?.full_name ?? companyName;
      companyLogo = getProfileImage(profileRows?.[0]?.profile_image_path);
    } catch {
      companyName = row.company;
    }

    shift = {
      ...shift,
      id: row.id,
      title: row.title,
      company: companyName,
      location: row.location,
      address: row.location,
      time: `${row.shift_date} · ${row.start_time.slice(0, 5)} - ${row.end_time.slice(0, 5)}`,
      pay: `€${Number(row.pay_rate).toFixed(2)}/hr`,
      logo: companyLogo,
    };
  } catch {
    return Astro.redirect("/worker/shifts?error=Could not load this shift.");
  }
}
---

<Layout title={`Apply for ${shift.title} | GigToGo`}>
  <main class="worker-ui">
    <AppSidebar accountType="worker" active="shifts" />

    <section class="worker-ui-main worker-apply-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search roles, companies or applications" />
        </div>

        <WorkerTopActions active="shifts" avatarImage={workerImage} />
      </header>

      <div class="worker-ui-breadcrumb">
        <a href="/worker/shifts">Available Shifts</a>
        <span>/</span>
        <a href={`/worker/shifts/${shift.id}`}>{shift.company}</a>
        <span>/</span>
        <strong>Apply</strong>
      </div>

      <section class="worker-apply-hero">
        <img src={shift.image} alt={`${shift.company} shift`} />
        <div class="worker-apply-hero-overlay"></div>
        <div>
          <p>Application review</p>
          <h1>Apply for {shift.title}</h1>
          <span>{shift.company} · {shift.location}</span>
        </div>
      </section>

      <section class="worker-apply-grid">
        <form class="worker-profile-panel worker-apply-form" method="POST" action="/api/shifts/apply">
          <input type="hidden" name="shift_id" value={shift.id} />
          <input type="hidden" name="back_to" value="/worker/applications" />
          <div class="worker-profile-panel-head">
            <div>
              <p>Your application</p>
              <h2>Confirm and send</h2>
            </div>
            <span>Fast apply</span>
          </div>

          <label>
            Availability
            <select>
              <option>I am available for the full shift</option>
              <option>I can do part of this shift</option>
              <option>I need to ask a question first</option>
            </select>
          </label>

          <label>
            Message to {shift.company}
            <textarea name="note" rows="5">Hi, I am available for this shift and my profile is up to date. I have relevant hospitality experience and can arrive on time.</textarea>
          </label>

          <div class="worker-apply-checks">
            <label>
              <input type="checkbox" checked />
              My availability is correct
            </label>
            <label>
              <input type="checkbox" checked />
              My profile and payment details are up to date
            </label>
          </div>

          <div class="worker-apply-actions">
            <button type="submit" class="btn btn-primary">
              Send application
              <i class="fa-solid fa-arrow-right"></i>
            </button>
            <a href={`/worker/shifts/${shift.id}`} class="btn btn-secondary">Back to shift</a>
          </div>
        </form>

        <aside class="worker-profile-panel worker-apply-summary">
          <div class="worker-apply-company">
            <img src={shift.logo} alt="" />
            <div>
              <strong>{shift.company}</strong>
              <span>{shift.title}</span>
            </div>
          </div>

          <div class="worker-apply-summary-list">
            <p>
              <i class="fa-regular fa-clock"></i>
              {shift.time}
            </p>
            <p>
              <i class="fa-solid fa-location-dot"></i>
              {shift.address}
            </p>
            <p>
              <i class="fa-solid fa-wallet"></i>
              {shift.pay} · {shift.total}
            </p>
          </div>
        </aside>

        <article class="worker-profile-panel worker-apply-profile-card">
          <div class="worker-profile-panel-head">
            <div>
              <p>Profile sent</p>
              <h2>Your profile</h2>
            </div>
            <span>Ready</span>
          </div>

          <div class="worker-apply-profile">
            <img src={workerImage} alt="Worker profile" />
            <div>
              <strong>Hospitality worker</strong>
              <span>Your account details are sent with the application.</span>
              <small>Keep your profile updated so businesses can review it.</small>
            </div>
          </div>
        </article>
      </section>
    </section>
  </main>
</Layout>
