---
import Layout from "../../../../layouts/layout.astro";
import AppSidebar from "../../../../components/AppSidebar.astro";
import WorkerTopActions from "../../../../components/workerTopActions.astro";

const applyShifts = [
  {
    id: "11111111-1111-4111-8111-111111111111",
    title: "Barista",
    company: "Butlers Chocolate Café",
    location: "Stoneybatter, Dublin",
    address: "12 Manor Street, Dublin 7",
    time: "Today · 2:00 PM - 8:00 PM",
    pay: "€14.50/hr",
    total: "€87.00 estimated",
    logo: "/butlers.jpg",
    image: "/butlers.jpg",
  },
  {
    id: "22222222-2222-4222-8222-222222222222",
    title: "Event Security",
    company: "Penneys",
    location: "O'Connell Street, Dublin",
    address: "O'Connell Street, Dublin 1",
    time: "Tomorrow · 6:00 PM - 12:00 AM",
    pay: "€17.00/hr",
    total: "€102.00 estimated",
    logo: "/penneys.jpg",
    image: "/penneys.jpg",
  },
  {
    id: "33333333-3333-4333-8333-333333333333",
    title: "Kitchen Porter",
    company: "Forno 500",
    location: "Dame Street, Dublin",
    address: "Dame Street, Dublin 2",
    time: "Fri · 7:00 AM - 3:00 PM",
    pay: "€15.80/hr",
    total: "€126.40 estimated",
    logo: "/forno.jpg",
    image: "/forno.jpg",
  },
  {
    id: "44444444-4444-4444-8444-444444444444",
    title: "Wait Staff",
    company: "Sophie's Restaurant & Bar",
    location: "Grafton Street, Dublin",
    address: "Grafton Street, Dublin 2",
    time: "Sat · 12:00 PM - 6:00 PM",
    pay: "€14.90/hr",
    total: "€89.40 estimated",
    logo: "/sophies.jpg",
    image: "/sophies.jpg",
  },
  {
    id: "55555555-5555-4555-8555-555555555555",
    title: "Shift Supervisor",
    company: "Starbucks",
    location: "Ranelagh, Dublin",
    address: "Ranelagh Road, Dublin 6",
    time: "Sun · 8:00 AM - 2:00 PM",
    pay: "€16.20/hr",
    total: "€97.20 estimated",
    logo: "/starbucks.jpg",
    image: "/starbucks.jpg",
  },
  {
    id: "66666666-6666-4666-8666-666666666666",
    title: "Front of House",
    company: "Maldron Hotel",
    location: "Smithfield, Dublin",
    address: "Smithfield, Dublin 7",
    time: "Mon · 9:00 AM - 5:00 PM",
    pay: "€15.40/hr",
    total: "€123.20 estimated",
    logo: "/maldron.jpg",
    image: "/maldron.jpg",
  },
];

export const prerender = false;

const shift = applyShifts.find((item) => item.id === Astro.params.id) ?? applyShifts[0];
---

<Layout title={`Apply for ${shift.title} | GigToGo`}>
  <main class="worker-ui">
    <AppSidebar accountType="worker" active="shifts" />

    <section class="worker-ui-main worker-apply-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search roles, companies or applications" />
        </div>

        <WorkerTopActions active="shifts" />
      </header>

      <div class="worker-ui-breadcrumb">
        <a href="/worker/shifts">Available Shifts</a>
        <span>/</span>
        <a href={`/worker/shifts/${shift.id}`}>{shift.company}</a>
        <span>/</span>
        <strong>Apply</strong>
      </div>

      <section class="worker-apply-hero">
        <img src={shift.image} alt={`${shift.company} shift`} />
        <div class="worker-apply-hero-overlay"></div>
        <div>
          <p>Application review</p>
          <h1>Apply for {shift.title}</h1>
          <span>{shift.company} · {shift.location}</span>
        </div>
      </section>

      <section class="worker-apply-grid">
        <form class="worker-profile-panel worker-apply-form" method="POST" action="/api/shifts/apply">
          <input type="hidden" name="shift_id" value={shift.id} />
          <input type="hidden" name="back_to" value="/worker/applications" />
          <div class="worker-profile-panel-head">
            <div>
              <p>Your application</p>
              <h2>Confirm and send</h2>
            </div>
            <span>Fast apply</span>
          </div>

          <label>
            Availability
            <select>
              <option>I am available for the full shift</option>
              <option>I can do part of this shift</option>
              <option>I need to ask a question first</option>
            </select>
          </label>

          <label>
            Message to {shift.company}
            <textarea name="note" rows="5">Hi, I am available for this shift and my profile is up to date. I have relevant hospitality experience and can arrive on time.</textarea>
          </label>

          <div class="worker-apply-checks">
            <label>
              <input type="checkbox" checked />
              My availability is correct
            </label>
            <label>
              <input type="checkbox" checked />
              My profile and payment details are up to date
            </label>
          </div>

          <div class="worker-apply-actions">
            <button type="submit" class="btn btn-primary">
              Send application
              <i class="fa-solid fa-arrow-right"></i>
            </button>
            <a href={`/worker/shifts/${shift.id}`} class="btn btn-secondary">Back to shift</a>
          </div>
        </form>

        <aside class="worker-profile-panel worker-apply-summary">
          <div class="worker-apply-company">
            <img src={shift.logo} alt="" />
            <div>
              <strong>{shift.company}</strong>
              <span>{shift.title}</span>
            </div>
          </div>

          <div class="worker-apply-summary-list">
            <p>
              <i class="fa-regular fa-clock"></i>
              {shift.time}
            </p>
            <p>
              <i class="fa-solid fa-location-dot"></i>
              {shift.address}
            </p>
            <p>
              <i class="fa-solid fa-wallet"></i>
              {shift.pay} · {shift.total}
            </p>
          </div>
        </aside>

        <article class="worker-profile-panel worker-apply-profile-card">
          <div class="worker-profile-panel-head">
            <div>
              <p>Profile sent</p>
              <h2>Mary O'Connor</h2>
            </div>
            <span>92% complete</span>
          </div>

          <div class="worker-apply-profile">
            <img src="/mary.jpg" alt="Mary O'Connor" />
            <div>
              <strong>Hospitality worker</strong>
              <span>36 jobs done · 4.9 rating</span>
              <small>Skills: Customer care, POS systems, food safety</small>
            </div>
          </div>
        </article>
      </section>
    </section>
  </main>
</Layout>
