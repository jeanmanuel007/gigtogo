---
import Layout from "../../layouts/layout.astro";
import AppSidebar from "../../components/AppSidebar.astro";
import WorkerTopActions from "../../components/workerTopActions.astro";
import { getProfileImage } from "../../lib/profileImages";
import { hasSupabaseConfig, supabaseFetch } from "../../lib/supabaseServer";

export const prerender = false;

const notice = Astro.url.searchParams.get("notice");
const error = Astro.url.searchParams.get("error");
const token = Astro.cookies.get("gigtogo_access_token")?.value;
const userId = Astro.cookies.get("gigtogo_user_id")?.value;
let workerImage = getProfileImage();

let shifts: Array<{
  id: string;
  title: string;
  company: string;
  type: string;
  location: string;
  time: string;
  pay: string;
  schedule: string;
  tag: string;
  logo: string;
  image: string;
}> = [];

if (hasSupabaseConfig() && !token) {
  return Astro.redirect("/auth/signin?error=Please sign in to view shifts.");
}

if (hasSupabaseConfig() && token) {
  try {
    if (userId) {
      const workerRows = await supabaseFetch(
        `/rest/v1/profiles?id=eq.${userId}&select=profile_image_path&limit=1`,
        { token }
      );
      workerImage = getProfileImage(workerRows?.[0]?.profile_image_path);
    }

    const rows = await supabaseFetch(
      "/rest/v1/shifts?status=eq.open&select=id,title,company,business_id,location,shift_date,start_time,end_time,pay_rate,shift_type&order=shift_date.asc",
      { token }
    );
    const businessIds = Array.from(new Set(rows.map((shift: any) => shift.business_id).filter(Boolean)));
    const businessLogos = new Map();

    if (businessIds.length > 0) {
      const profiles = await supabaseFetch(
        `/rest/v1/profiles?id=in.(${businessIds.join(",")})&select=id,profile_image_path`,
        { token }
      );

      for (const profile of profiles) {
        businessLogos.set(profile.id, profile.profile_image_path);
      }
    }

    shifts = rows.map((shift: any) => {
      const logo = getProfileImage(businessLogos.get(shift.business_id));

      return {
        id: shift.id,
        title: shift.title,
        company: shift.company,
        type: shift.shift_type ?? "Flexible",
        location: shift.location,
        time: `${shift.shift_date} · ${shift.start_time.slice(0, 5)} - ${shift.end_time.slice(0, 5)}`,
        pay: `€${Number(shift.pay_rate).toFixed(2)}/hr`,
        schedule: "Open shift",
        distance: "",
        tag: "Available",
        logo,
        image: logo,
      };
    });
  } catch {
    shifts = [];
  }
}
---

<Layout title="Available Shifts | GigToGo">
  <main class="worker-ui">
    <AppSidebar accountType="worker" active="shifts" />

    <section class="worker-ui-main worker-vacancies-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search roles, companies or locations" />
        </div>

        <WorkerTopActions active="shifts" avatarImage={workerImage} />
      </header>

      <div class="worker-ui-breadcrumb">
        <span>Dashboard</span>
        <span>/</span>
        <strong>Available Shifts</strong>
      </div>

      {error && <p class="auth-alert error">{error}</p>}
      {notice && <p class="auth-alert notice">{notice}</p>}

      <section class="worker-vacancies-hero">
        <img src="/image_home_1.png" alt="Available shifts banner" />
        <div class="worker-vacancies-hero-overlay"></div>
        <h1>Find a shift close to you</h1>
      </section>

      <section class="worker-ui-toolbar">
        <div class="worker-ui-subsearch">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search on Available Shifts" />
        </div>

        <button type="button" class="worker-vacancies-filter" aria-label="Filter available shifts">
          <i class="fa-solid fa-sliders"></i>
        </button>
      </section>

      <section class="worker-vacancy-grid" id="shift-results">
        {shifts.map((shift) => (
          <article class="worker-vacancy-card">
            <div class="worker-vacancy-image">
              <img src={shift.image} alt={`${shift.company} workplace`} />
              <div class="worker-vacancy-overlay">
                <div class="worker-vacancy-company">
                  <img src={shift.logo} alt="" />
                  <span>{shift.company}</span>
                </div>

                <div class="worker-vacancy-image-actions">
                  <a href={`/worker/shifts/${shift.id}`} class="btn btn-secondary" aria-label={`View ${shift.title} at ${shift.company}`}>
                    View shift
                  </a>
                  <a href={`/worker/shifts/${shift.id}#apply`} class="btn btn-primary">
                    Quick apply
                  </a>
                </div>
              </div>
            </div>

            <div class="worker-vacancy-body">
              <span class="worker-vacancy-line"></span>
              <div class="worker-vacancy-meta-row">
                <small>{shift.type}</small>
                <em>{shift.pay}</em>
              </div>
              <h3>{shift.title}</h3>

              <p>
                <i class="fa-solid fa-location-dot"></i>
                {shift.location}
              </p>
              <p>
                <i class="fa-regular fa-clock"></i>
                {shift.time}
              </p>
              <div class="worker-vacancy-foot">
                <span>{shift.schedule}</span>
                <span>{shift.tag}</span>
              </div>
            </div>
          </article>
        ))}
      </section>
    </section>
  </main>
</Layout>
