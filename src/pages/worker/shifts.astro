---
import Layout from "../../layouts/layout.astro";
import AppSidebar from "../../components/AppSidebar.astro";
import WorkerTopActions from "../../components/workerTopActions.astro";

export const prerender = false;

const fallbackShifts = [
  {
    id: "11111111-1111-4111-8111-111111111111",
    title: "Barista",
    company: "Butlers Chocolate Café",
    type: "Part-time",
    location: "Stoneybatter, Dublin",
    time: "Today · 2:00 PM - 8:00 PM",
    pay: "€14.50/hr",
    schedule: "20 hours/Week",
    distance: "1.8 km away",
    tag: "Fast apply",
    logo: "/butlers.jpg",
    image: "/butlers.jpg",
  },
  {
    id: "22222222-2222-4222-8222-222222222222",
    title: "Event Security",
    company: "Penneys",
    type: "Evening",
    location: "O'Connell Street, Dublin",
    time: "Tomorrow · 6:00 PM - 12:00 AM",
    pay: "€17.00/hr",
    schedule: "8 hours/Week",
    distance: "3.2 km away",
    tag: "Urgent",
    logo: "/penneys.jpg",
    image: "/penneys.jpg",
  },
  {
    id: "33333333-3333-4333-8333-333333333333",
    title: "Kitchen Porter",
    company: "Forno 500",
    type: "Full-time",
    location: "Dame Street, Dublin",
    time: "Fri · 7:00 AM - 3:00 PM",
    pay: "€15.80/hr",
    schedule: "40 hours/Week",
    distance: "4.1 km away",
    tag: "New",
    logo: "/forno.jpg",
    image: "/forno.jpg",
  },
  {
    id: "44444444-4444-4444-8444-444444444444",
    title: "Wait Staff",
    company: "Sophie's Restaurant & Bar",
    type: "Weekend",
    location: "Grafton Street, Dublin",
    time: "Sat · 12:00 PM - 6:00 PM",
    pay: "€14.90/hr",
    schedule: "Weekend shift",
    distance: "2.6 km away",
    tag: "Popular",
    logo: "/sophies.jpg",
    image: "/sophies.jpg",
  },
  {
    id: "55555555-5555-4555-8555-555555555555",
    title: "Shift Supervisor",
    company: "Starbucks",
    type: "Morning",
    location: "Ranelagh, Dublin",
    time: "Sun · 8:00 AM - 2:00 PM",
    pay: "€16.20/hr",
    schedule: "Morning shift",
    distance: "5.4 km away",
    tag: "Featured",
    logo: "/starbucks.jpg",
    image: "/starbucks.jpg",
  },
  {
    id: "66666666-6666-4666-8666-666666666666",
    title: "Front of House",
    company: "Maldron Hotel",
    type: "Flexible",
    location: "Smithfield, Dublin",
    time: "Mon · 9:00 AM - 5:00 PM",
    pay: "€15.40/hr",
    schedule: "Flexible shift",
    distance: "2.9 km away",
    tag: "Verified",
    logo: "/maldron.jpg",
    image: "/maldron.jpg",
  },
];

const notice = Astro.url.searchParams.get("notice");
const error = Astro.url.searchParams.get("error");

const shifts = fallbackShifts;
---

<Layout title="Available Shifts | GigToGo">
  <main class="worker-ui">
    <AppSidebar accountType="worker" active="shifts" />

    <section class="worker-ui-main worker-vacancies-page">
      <header class="worker-ui-topbar">
        <div class="worker-ui-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search roles, companies or locations" />
        </div>

        <WorkerTopActions active="shifts" />
      </header>

      <div class="worker-ui-breadcrumb">
        <span>Dashboard</span>
        <span>/</span>
        <strong>Available Shifts</strong>
      </div>

      {error && <p class="auth-alert error">{error}</p>}
      {notice && <p class="auth-alert notice">{notice}</p>}

      <section class="worker-vacancies-hero">
        <img src="/image_home_1.png" alt="Available shifts banner" />
        <div class="worker-vacancies-hero-overlay"></div>
        <h1>Find a shift close to you</h1>
      </section>

      <section class="worker-ui-toolbar">
        <div class="worker-ui-subsearch">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search on Available Shifts" />
        </div>

        <button type="button" class="worker-vacancies-filter" aria-label="Filter available shifts">
          <i class="fa-solid fa-sliders"></i>
        </button>
      </section>

      <section class="worker-vacancy-grid" id="shift-results">
        {shifts.map((shift) => (
          <article class="worker-vacancy-card">
            <div class="worker-vacancy-image">
              <img src={shift.image} alt={`${shift.company} workplace`} />
              <div class="worker-vacancy-overlay">
                <div class="worker-vacancy-company">
                  <img src={shift.logo} alt="" />
                  <span>{shift.company}</span>
                </div>

                <div class="worker-vacancy-image-actions">
                  <a href={`/worker/shifts/${shift.id}`} class="btn btn-secondary" aria-label={`View ${shift.title} at ${shift.company}`}>
                    View shift
                  </a>
                  <a href={`/worker/shifts/${shift.id}#apply`} class="btn btn-primary">
                    Quick apply
                  </a>
                </div>
              </div>
            </div>

            <div class="worker-vacancy-body">
              <span class="worker-vacancy-line"></span>
              <div class="worker-vacancy-meta-row">
                <small>{shift.type}</small>
                <em>{shift.pay}</em>
              </div>
              <h3>{shift.title}</h3>

              <p>
                <i class="fa-solid fa-location-dot"></i>
                {shift.location}
              </p>
              <p>
                <i class="fa-regular fa-clock"></i>
                {shift.time}
              </p>
              <div class="worker-vacancy-foot">
                <span>{shift.schedule}</span>
                <span>{shift.tag}</span>
              </div>
            </div>
          </article>
        ))}
      </section>
    </section>
  </main>
</Layout>
